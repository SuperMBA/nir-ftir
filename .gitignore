# ---------------- data ----------------

# Сырые и промежуточные данные 
data/raw/
data/interim/
data/.DS_Store

# processed: по умолчанию игнорируем всё, кроме ключевых parquet
data/processed/*
!data/processed/
!data/processed/train.parquet
!data/processed/external.parquet
!data/processed/train_diabetes.parquet


# ---------------- reports ----------------
# Все отчёты/артефакты по умолчанию не версионируем
reports/**

!reports/
!reports/.gitkeep

# Храним только агрегированные summary 
!reports/summary_runs.csv
!reports/exp/
!reports/exp/summary.csv


# ---- EDA / QC ----
# Храним только "latest" (то, что делает eda_qc.py),
# а отдельные ран-ид каталоги игнорируем
reports/eda_qc/*
!reports/eda_qc/
!reports/eda_qc/latest/
!reports/eda_qc/latest/**

# ---- Experiments ----
# Игнорим всё внутри reports/exp, кроме ключевых файлов
reports/exp/*
!reports/exp/
!reports/exp/**/
!reports/exp/summary.csv
!reports/exp/*/config.json
!reports/exp/*/cv_metrics.csv
!reports/exp/*/test_metrics.csv
!reports/exp/*/test_metrics_all.csv
!reports/exp/*/qc_synthetic.json
!reports/exp/*/confusion_test.json
!reports/exp/*/calibration_test.json
!reports/exp/*/curves.npz
!data/processed/diabetes_saliva.parquet

# ---------------- служебное / окружение ----------------

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# Виртуальные окружения
.env
.venv/
venv/

# MLflow и прочие артефакты трекинга
mlflow.db
mlruns/
.micromamba/
.conda/

# local aggregated artifacts
summary_runs_from_json.csv